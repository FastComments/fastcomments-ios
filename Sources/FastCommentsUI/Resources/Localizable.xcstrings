        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "댓글을 불러오는 중 오류가 발생했습니다. 나중에 다시 시도해주세요."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
