          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ocorreu um erro ao carregar comentários. Por favor, tente novamente mais tarde."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "A apărut o eroare la încărcarea comentariilor. Te rugăm să încerci mai târziu."
