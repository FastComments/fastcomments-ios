    "comment_anon_notice": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can comment as a guest, but your name will be shown with your comment."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kannst als Gast kommentieren, aber dein Name wird mit deinem Kommentar angezeigt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes comentar como invitado, pero tu nombre se mostrará con tu comentario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez commenter en tant qu'invité, mais votre nom sera affiché avec votre commentaire."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Puoi commentare come ospite, ma il tuo nome verrà mostrato con il tuo commento."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ゲストとしてコメントできますが、あなたの名前がコメントと一緒に表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "게스트로 댓글을 작성할 수 있지만 이름이 댓글과 함께 표시됩니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Możesz komentować jako gość, ale Twoje imię będzie wyświetlane przy komentarzu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você pode comentar como convidado, mas seu nome será exibido com seu comentário."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Poți comenta ca invitat, dar numele tău va fi afișat cu comentariul tău."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы можете комментировать как гость, но ваше имя будет показано с вашим комментарием."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kan kommentera som gäst, men ditt namn kommer att visas med din kommentar."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Misafir olarak yorum yapabilirsiniz, ancak adınız yorumunuzla birlikte gösterilecektir."
          }
        }
      }
    },
